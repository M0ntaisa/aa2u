# Public site URL
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (from your Supabase project settings)
# When SUPABASE_URL contains "placeholder" the app falls back to dummy data
# in /data, so the site renders before you've set up a real project.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key
# Server-only key — used by /api/inquiries to insert into the inquiries
# table while bypassing RLS. Never expose to the client.
SUPABASE_SERVICE_KEY=your-service-role-key
